# Xero MCP Server
# https://github.com/XeroAPI/xero-mcp-server
#
# Three auth modes — pick ONE:
#
#   1. OAuth2 Authorization Code (free, recommended)
#      Set XERO_CLIENT_ID + XERO_CLIENT_SECRET, then run:
#        node scripts/oauth.mjs
#      This opens your browser, you authorize, and it saves XERO_REFRESH_TOKEN
#      below. The container auto-refreshes the access token on every startup.
#
#   2. Custom Connection (paid Xero feature)
#      Set XERO_CLIENT_ID + XERO_CLIENT_SECRET only (no refresh token).
#      Uses the client-credentials grant — no browser flow needed.
#      Setup: https://developer.xero.com/documentation/guides/oauth2/custom-connections/
#
#   3. Bearer Token (manual / PKCE)
#      Set XERO_CLIENT_BEARER_TOKEN directly.
#      Takes precedence over everything else. Expires in ~30 minutes.

# ── Xero app credentials ────────────────────────────────────────────────────
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret

# ── OAuth2 refresh token (written by scripts/oauth.mjs) ─────────────────────
# XERO_REFRESH_TOKEN=

# ── Bearer token (manual override) ──────────────────────────────────────────
# XERO_CLIENT_BEARER_TOKEN=your-bearer-token

# ── Gateway options ──────────────────────────────────────────────────────────
# Protect the supergateway endpoint with a static bearer token (optional)
# MCP_BEARER_TOKEN=your-secret-token

# Output transport (default: streamableHttp)
# MCP_TRANSPORT=streamableHttp
